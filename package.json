{
  "name": "shovel-be",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",

    "start": "node --import=./dist/instrumentation/setup.js dist/index.js",
    "start:dev": "DOTENV_PATH=env/.env.dev npm run start",
    "start:mock": "DOTENV_PATH=env/.env.mock npm run start",
    "start:testnet": "DOTENV_PATH=env/.env.testnet npm run start",
    "start:prod": "DOTENV_PATH=env/.env.prod npm run start",

    "dev": "nodemon --exec tsx --import=./src/instrumentation/setup.ts src/index.ts",
    "dev:dev": "DOTENV_PATH=env/.env.dev npm run dev",
    "dev:mock": "DOTENV_PATH=env/.env.mock npm run dev",
    "dev:testnet": "DOTENV_PATH=env/.env.testnet npm run dev",
    "dev:prod": "DOTENV_PATH=env/.env.prod npm run dev",
    
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage && open coverage/index.html",
    "lint": "eslint",
    "plop": "cross-env NODE_OPTIONS='--import tsx' plop --plopfile=plopfile.ts",
    "init": "npm run plop init"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@dotenvx/dotenvx": "^1.51.0",
    "@opentelemetry/auto-instrumentations-node": "^0.65.0",
    "@opentelemetry/sdk-node": "^0.206.0",
    "bip322-js": "^3.0.0",
    "bitcoinjs-lib": "^7.0.0",
    "cbor2": "^2.0.1",
    "cors": "^2.8.5",
    "ecpair": "^3.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jiti": "^2.6.1",
    "joi": "^18.0.1",
    "js-big-decimal": "^2.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.20.0",
    "zod": "^4.1.12",
    "zod-validation-error": "^4.0.2"
  },
  "devDependencies": {
    "@azure/identity": "^4.12.0",
    "@azure/keyvault-secrets": "^4.10.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.0",
    "@types/seedrandom": "^3.0.8",
    "@vitest/coverage-istanbul": "3.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.37.0",
    "mongodb-memory-server": "^10.2.2",
    "nodemon": "^3.1.10",
    "plop": "^4.0.4",
    "seedrandom": "^3.0.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^3.2.4",
    "vitest-fetch-mock": "^0.4.5"
  }
}
